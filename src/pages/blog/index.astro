---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Writing" description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main id="main-content">
      <div class="page-header reveal">
        <h1>Writing</h1>
        <p class="page-subtitle">
          {posts.length} {posts.length === 1 ? 'essay' : 'essays'} on ideas, craft, and the world.
        </p>
      </div>

      <ul class="post-list" role="list">
        {
          posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`} class="post-link">
                {post.data.heroImage && (
                  <div class="post-image">
                    <Image
                      width={600}
                      height={340}
                      src={post.data.heroImage}
                      alt=""
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="post-body">
                  <time class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </time>
                  <h2 class="post-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="post-description">{post.data.description}</p>
                  )}
                  <span class="post-read-more" aria-hidden="true">Read →</span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: var(--max-wide);
    max-width: calc(100% - 3rem);
    margin: 0 auto;
    padding: 0 0 6rem;
  }

  /* ─── Page Header ─── */
  .page-header {
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--surface-border);
    margin-bottom: 3rem;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 0.5rem;
  }

  .page-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    margin: 0;
  }

  /* ─── Post List ─── */
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .post-item {
    border-bottom: 1px solid var(--surface-border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 2rem;
    align-items: start;
    padding: 2rem 0;
    text-decoration: none;
    transition: none;
  }

  /* ─── Post Image (right-side thumbnail) ─── */
  .post-image {
    grid-column: 2;
    grid-row: 1;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    transition: transform var(--dur-normal) var(--ease-out);
  }

  .post-link:hover .post-image img {
    transform: scale(1.04);
  }

  /* ─── Post Body ─── */
  .post-body {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .post-date {
    display: block;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 500;
    color: var(--text-primary);
    line-height: 1.3;
    margin: 0;
    letter-spacing: -0.01em;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-description {
    font-size: 0.9375rem;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-read-more {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: 0.25rem;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .post-link:hover .post-read-more {
    color: var(--accent-hover);
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .post-link {
      grid-template-columns: 1fr;
    }
    .post-image {
      grid-column: 1;
      grid-row: 1;
    }
    .post-body {
      grid-row: 2;
    }
    .page-header { padding: 3rem 0 2rem; }
  }
</style>
