---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Search" description="Search posts, projects, and research across The Deep Field." />
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  </head>
  <body>
    <Header />

    <main id="main-content">
      <section class="search-hero">
        <div class="eyebrow">
          <span class="eyebrow-dot" aria-hidden="true">◉</span>
          Search
        </div>
        <h1 class="page-title">Find anything.</h1>
      </section>

      <div class="search-wrapper">
        <div id="search"></div>
      </div>

      <div class="search-note" id="search-note">
        <p>Search is available after running <code>npm run build</code>. In dev mode, results won't appear.</p>
      </div>
    </main>

    <Footer />

    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        if (typeof window.PagefindUI !== 'undefined') {
          new window.PagefindUI({
            element: '#search',
            showSubResults: true,
            showImages: false,
            resetStyles: false,
          });
          const note = document.getElementById('search-note');
          if (note) note.style.display = 'none';
        }
      });
    </script>
  </body>
</html>

<style>
  main {
    width: var(--max-wide);
    max-width: calc(100% - 3rem);
    margin: 0 auto;
    padding: 0 0 6rem;
  }

  .search-hero {
    padding: 6rem 0 3rem;
    max-width: 680px;
  }

  .search-wrapper {
    max-width: 720px;
    margin-bottom: 2rem;
  }

  .search-note {
    max-width: 720px;
    padding: 1rem 1.25rem;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-sm);
    background: var(--surface-card);
  }

  .search-note p {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .search-note code {
    font-family: monospace;
    font-size: 0.85em;
    padding: 0.1em 0.35em;
    background: var(--surface-raised);
    border-radius: 3px;
    color: var(--accent);
  }

  :root {
    --pagefind-ui-scale: 0.95;
    --pagefind-ui-primary: var(--accent);
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--surface-bg);
    --pagefind-ui-border: var(--surface-border);
    --pagefind-ui-tag: var(--surface-raised);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-sans);
  }

  @media (max-width: 640px) {
    .search-hero { padding: 3.5rem 0 2rem; }
  }
</style>
