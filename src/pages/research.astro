---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, GITHUB_URL, ORCID_URL } from '../consts';

const papers = [
  // Add your papers here as they come. Format:
  // {
  //   title: 'Paper Title',
  //   authors: 'Sasidhar, A., et al.',
  //   venue: 'Conference / Journal Name, Year',
  //   abstract: 'Short abstract or summary.',
  //   links: { pdf: '', arxiv: '', code: '' },
  //   status: 'Published' | 'Preprint' | 'In Review',
  // },
];

const areas = [
  {
    title: 'Language Model Architectures',
    description: 'Exploring efficiency in transformer variants — mixture of experts, dynamic depth, and what happens when you take these ideas to very small scale.',
    icon: '◈',
  },
  {
    title: 'AI Agents & Tool Use',
    description: 'Building and studying agents that interact with the real world through tools — browsers, CLIs, APIs. How do you make them reliable?',
    icon: '◎',
  },
  {
    title: 'Local & Private AI',
    description: 'Making capable AI systems that run entirely on-device. Privacy, latency, and the question of what you actually need a cloud for.',
    icon: '◇',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Research — ${SITE_TITLE}`}
      description="Research interests, papers, and experiments in AI, language models, and intelligent systems."
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="research-hero">
        <div class="eyebrow">
          <span class="eyebrow-dot" aria-hidden="true">◉</span>
          Research
        </div>
        <h1 class="page-title">Work at the frontier.</h1>
        <p class="page-subtitle">
          Papers, experiments, and open questions in AI and machine learning.
        </p>
        <div class="hero-links">
          <a href={ORCID_URL} target="_blank" rel="noopener noreferrer" class="meta-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947-.947-.431-.947-.947.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.822-1.609 3.822-3.722 0-1.847-1.247-3.722-3.822-3.722h-2.297z"/>
            </svg>
            ORCID
          </a>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="meta-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub experiments
          </a>
        </div>
      </section>

      <div class="section-divider" aria-hidden="true"></div>

      <!-- Papers -->
      <section class="papers-section">
        <header class="section-header">
          <h2 class="section-label">Papers</h2>
        </header>

        {papers.length > 0 ? (
          <ul class="paper-list" role="list">
            {papers.map((paper) => (
              <li class="paper-item">
                <div class="paper-header">
                  <h3 class="paper-title">{paper.title}</h3>
                  <span class={`paper-status status-${paper.status.toLowerCase().replace(' ', '-')}`}>
                    {paper.status}
                  </span>
                </div>
                <p class="paper-authors">{paper.authors}</p>
                <p class="paper-venue">{paper.venue}</p>
                {paper.abstract && <p class="paper-abstract">{paper.abstract}</p>}
                <div class="paper-links">
                  {paper.links.pdf && <a href={paper.links.pdf} target="_blank" rel="noopener noreferrer" class="paper-link">PDF</a>}
                  {paper.links.arxiv && <a href={paper.links.arxiv} target="_blank" rel="noopener noreferrer" class="paper-link">arXiv</a>}
                  {paper.links.code && <a href={paper.links.code} target="_blank" rel="noopener noreferrer" class="paper-link">Code</a>}
                </div>
              </li>
            ))}
          </ul>
        ) : (
          <div class="empty-state">
            <span class="empty-icon" aria-hidden="true">◎</span>
            <p>Papers in progress. Check back soon — or watch the <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a> for experiments that might turn into something.</p>
          </div>
        )}
      </section>

      <div class="section-divider" aria-hidden="true"></div>

      <!-- Research areas -->
      <section class="areas-section">
        <header class="section-header">
          <h2 class="section-label">Areas</h2>
        </header>

        <div class="areas-grid">
          {areas.map((area) => (
            <div class="area-card">
              <span class="area-icon" aria-hidden="true">{area.icon}</span>
              <h3 class="area-title">{area.title}</h3>
              <p class="area-description">{area.description}</p>
            </div>
          ))}
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: var(--max-wide);
    max-width: calc(100% - 3rem);
    margin: 0 auto;
    padding: 0 0 6rem;
  }

  /* ─── Hero ─── */
  .research-hero {
    padding: 6rem 0 5rem;
    max-width: 680px;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .eyebrow-dot {
    font-size: 0.7rem;
    animation: pulse 3s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .page-title {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 400;
    font-family: var(--font-serif);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .page-subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .meta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-sm);
    transition:
      color var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .meta-link:hover {
    color: var(--text-primary);
    background: var(--surface-raised);
    border-color: var(--surface-divider);
    text-decoration: none;
  }

  /* ─── Divider ─── */
  .section-divider {
    height: 1px;
    background: var(--surface-border);
    margin: 1rem 0 4rem;
  }

  /* ─── Section header ─── */
  .section-header {
    margin-bottom: 2rem;
  }

  .section-label {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }

  /* ─── Papers ─── */
  .paper-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .paper-item {
    padding: 2rem 0;
    border-top: 1px solid var(--surface-border);
  }

  .paper-item:last-child {
    border-bottom: 1px solid var(--surface-border);
  }

  .paper-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }

  .paper-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.35;
  }

  .paper-status {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.2em 0.6em;
    border-radius: 100px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status-published {
    color: #5a9a6b;
    background: rgba(90,154,107,0.1);
    border: 1px solid rgba(90,154,107,0.2);
  }

  .status-preprint {
    color: var(--brand-coral, #D4785A);
    background: rgba(212,120,90,0.1);
    border: 1px solid rgba(212,120,90,0.2);
  }

  .status-in-review {
    color: #7c8ab8;
    background: rgba(124,138,184,0.1);
    border: 1px solid rgba(124,138,184,0.2);
  }

  .paper-authors {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0 0 0.2rem;
  }

  .paper-venue {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0 0 0.75rem;
  }

  .paper-abstract {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0 0 1rem;
    max-width: 680px;
  }

  .paper-links {
    display: flex;
    gap: 0.5rem;
  }

  .paper-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-sm);
    transition:
      background-color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }

  .paper-link:hover {
    background: var(--surface-raised);
    border-color: var(--surface-divider);
    text-decoration: none;
  }

  /* ─── Empty state ─── */
  .empty-state {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 2.5rem 0;
    border-top: 1px solid var(--surface-border);
    border-bottom: 1px solid var(--surface-border);
  }

  .empty-icon {
    font-size: 1.25rem;
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .empty-state p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0;
  }

  .empty-state a {
    color: var(--accent);
    text-decoration: none;
  }

  .empty-state a:hover {
    text-decoration: underline;
  }

  /* ─── Research areas ─── */
  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .area-card {
    padding: 1.5rem;
    border: 1px solid var(--surface-border);
    border-radius: var(--radius-md);
    background: var(--surface-card);
  }

  .area-icon {
    display: block;
    font-size: 1.25rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .area-title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0 0 0.6rem;
  }

  .area-description {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .research-hero { padding: 3.5rem 0 3rem; }
    .areas-grid { grid-template-columns: 1fr; }
  }
</style>
