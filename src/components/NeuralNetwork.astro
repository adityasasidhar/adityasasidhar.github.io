---
---

<div class="neuron-container">
  <canvas id="ann-canvas"></canvas>
</div>

<script>
  function initANN() {
    const canvas = document.getElementById('ann-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = canvas.parentElement?.clientWidth || 800;
    let height = canvas.parentElement?.clientHeight || 472;
    canvas.width = width;
    canvas.height = height;

    window.addEventListener('resize', () => {
      width = canvas.parentElement?.clientWidth || 800;
      height = canvas.parentElement?.clientHeight || 472;
      canvas.width = width;
      canvas.height = height;
      buildNetwork();
    });

    function getColors() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      return {
        nodeColor: isDark ? 'rgba(212, 120, 90, 0.8)' : 'rgba(212, 120, 90, 0.6)',
        lineColor: isDark ? 'rgba(212, 120, 90, 0.25)' : 'rgba(212, 120, 90, 0.15)',
        activationColor: isDark ? 'rgba(255, 230, 200, 1)' : 'rgba(212, 120, 90, 1)',
      };
    }

    let colors = getColors();

    const themeObserver = new MutationObserver(() => {
      colors = getColors();
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    interface Node {
      x: number;
      y: number;
      radius: number;
      baseRadius: number;
      layer: number;
      targetX: number;
      targetY: number;
    }

    interface Connection {
      from: Node;
      to: Node;
      width: number;
      distance: number;
    }

    interface Activation {
      connection: Connection;
      progress: number;
      speed: number;
    }

    let nodes: Node[] = [];
    let connections: Connection[] = [];
    let activations: Activation[] = [];

    let time = 0;

    function random(min: number, max: number) {
      return Math.random() * (max - min) + min;
    }

    function buildNetwork() {
      nodes = [];
      connections = [];
      activations = [];

      const numLayers = Math.floor(width / 150) + 1;

      const paddingX = 60;
      const paddingY = 60;
      const usableWidth = width - paddingX * 2;
      const usableHeight = height - paddingY * 2;

      const maxNodes = Math.floor(usableHeight / 57.5) + 1;

      const layerSizes = [];
      for (let i = 0; i < numLayers; i++) {
        if (i === 0 || i === numLayers - 1) {
          layerSizes.push(Math.floor(random(3, Math.min(6, maxNodes))));
        } else {
          layerSizes.push(Math.floor(random(4, Math.min(10, maxNodes + 1))));
        }
      }

      const layerRadii = [];
      for (let i = 0; i < numLayers; i++) {
        layerRadii.push(random(6.25, 25));
      }

      for (let l = 0; l < numLayers; l++) {
        const layerX = paddingX + (l / (numLayers - 1)) * usableWidth;
        const numNodesInLayer = layerSizes[l];

        const layerHeight = (numNodesInLayer - 1) * 57.5;
        const startY = (height - layerHeight) / 2;

        const baseRadius = layerRadii[l];

        for (let n = 0; n < numNodesInLayer; n++) {
          const x = layerX + random(-10, 10);
          const y = startY + n * 57.5 + random(-10, 10);

          nodes.push({
            x, y,
            targetX: x, targetY: y,
            radius: baseRadius,
            baseRadius,
            layer: l
          });
        }
      }

      for (let i = 0; i < nodes.length; i++) {
        const nodeA = nodes[i];

        const candidates = nodes.filter(n => n.layer === nodeA.layer + 1);

        candidates.sort(() => 0.5 - Math.random());
        const numConnections = Math.floor(random(2, 5));

        for (let j = 0; j < Math.min(numConnections, candidates.length); j++) {
          const nodeB = candidates[j];
          const dx = nodeB.x - nodeA.x;
          const dy = nodeB.y - nodeA.y;
          const distance = Math.sqrt(dx*dx + dy*dy);

          connections.push({
            from: nodeA,
            to: nodeB,
            width: random(1, 2.5),
            distance
          });
        }
      }
    }

    function spawnActivation() {
      if (connections.length === 0) return;
      const connection = connections[Math.floor(Math.random() * connections.length)];
      activations.push({
        connection,
        progress: 0,
        speed: random(0.003, 0.008)
      });
    }

    function animate() {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);

      time += 0.005;

      ctx.lineCap = 'round';
      for (const conn of connections) {
        ctx.beginPath();
        ctx.moveTo(conn.from.x, conn.from.y);
        ctx.lineTo(conn.to.x, conn.to.y);
        ctx.strokeStyle = colors.lineColor;
        ctx.lineWidth = conn.width;
        ctx.stroke();
      }

      if (Math.random() < 0.03) spawnActivation();

      for (let i = activations.length - 1; i >= 0; i--) {
        const act = activations[i];
        act.progress += act.speed;

        if (act.progress >= 1) {
          activations.splice(i, 1);
          if (Math.random() > 0.8) {
             const nextConns = connections.filter(c => c.from === act.connection.to);
             if(nextConns.length > 0) {
                 const next = nextConns[Math.floor(Math.random() * nextConns.length)];
                 activations.push({ connection: next, progress: 0, speed: random(0.003, 0.008) });
             }
          }
          continue;
        }

        const x = act.connection.from.x + (act.connection.to.x - act.connection.from.x) * act.progress;
        const y = act.connection.from.y + (act.connection.to.y - act.connection.from.y) * act.progress;

        ctx.beginPath();
        ctx.arc(x, y, act.connection.width + 1.5, 0, Math.PI * 2);
        ctx.fillStyle = colors.activationColor;
        ctx.shadowColor = colors.activationColor;
        ctx.shadowBlur = 6;
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      for (const node of nodes) {
        ctx.beginPath();
        const currentRadius = node.baseRadius + Math.sin(time + node.x) * 0.5;
        ctx.arc(node.x, node.y, Math.max(1, currentRadius), 0, Math.PI * 2);
        ctx.fillStyle = colors.nodeColor;
        ctx.fill();

        ctx.strokeStyle = '#111111';
        ctx.lineWidth = 2.5;
        ctx.stroke();

        if (node.baseRadius > 10) {
          ctx.beginPath();
          ctx.arc(node.x, node.y, node.baseRadius * 0.3, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255,255,255,0.15)';
          ctx.fill();
        }
      }

      requestAnimationFrame(animate);
    }

    buildNetwork();
    animate();
  }

  initANN();
  document.addEventListener('astro:page-load', initANN);
</script>

<style>
  .neuron-container {
    width: 100%;
    height: 472px;
    background: radial-gradient(circle at center, var(--surface-card) 0%, var(--surface-bg) 100%);
    border-radius: var(--radius-lg);
    border: 1px solid var(--surface-border);
    margin: 3rem 0 4rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }
</style>
