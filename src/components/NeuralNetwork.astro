---
// NeuralNetwork.astro
---

<div class="neuron-container">
  <canvas id="ann-canvas"></canvas>
</div>

<script>
  function initANN() {
    const canvas = document.getElementById('ann-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = canvas.parentElement?.clientWidth || 800;
    let height = canvas.parentElement?.clientHeight || 472;
    canvas.width = width;
    canvas.height = height;

    window.addEventListener('resize', () => {
      width = canvas.parentElement?.clientWidth || 800;
      height = canvas.parentElement?.clientHeight || 472;
      canvas.width = width;
      canvas.height = height;
      buildNetwork();
    });

    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    // Aesthetic colors based on theme
    const nodeColor = isDark ? 'rgba(212, 120, 90, 0.8)' : 'rgba(212, 120, 90, 0.6)';
    const lineColor = isDark ? 'rgba(212, 120, 90, 0.25)' : 'rgba(212, 120, 90, 0.15)';
    const activationColor = isDark ? 'rgba(255, 230, 200, 1)' : 'rgba(212, 120, 90, 1)';

    interface Node {
      x: number;
      y: number;
      radius: number;
      baseRadius: number;
      layer: number;
      targetX: number;
      targetY: number;
    }

    interface Connection {
      from: Node;
      to: Node;
      width: number;
      distance: number;
    }

    interface Activation {
      connection: Connection;
      progress: number;
      speed: number;
    }

    let nodes: Node[] = [];
    let connections: Connection[] = [];
    let activations: Activation[] = [];

    let time = 0;

    function random(min: number, max: number) {
      return Math.random() * (max - min) + min;
    }

    function buildNetwork() {
      nodes = [];
      connections = [];
      activations = [];

      // Determine network structure
      const numLayers = Math.floor(width / 150) + 1; // e.g., 5-6 layers on desktop

      const paddingX = 60;
      const paddingY = 60;
      const usableWidth = width - paddingX * 2;
      const usableHeight = height - paddingY * 2;

      // Define layer sizes with more interesting variety, but constrain to canvas height
      const maxNodes = Math.floor(usableHeight / 57.5) + 1;

      const layerSizes = [];
      for (let i = 0; i < numLayers; i++) {
        // Outer layers have fewer nodes, inner layers have highly variable numbers
        if (i === 0 || i === numLayers - 1) {
          layerSizes.push(Math.floor(random(3, Math.min(6, maxNodes)))); // 3 to 5 nodes
        } else {
          // Inner hidden layers are wildcards but capped by the available height
          layerSizes.push(Math.floor(random(4, Math.min(10, maxNodes + 1))));
        }
      }

      // Define a specific radius for each layer to make layers distinct
      const layerRadii = [];
      for (let i = 0; i < numLayers; i++) {
        // Create a distinct size for each layer, increased by 25%
        layerRadii.push(random(6.25, 25));
      }

      // Create nodes in neat columns
      for (let l = 0; l < numLayers; l++) {
        const layerX = paddingX + (l / (numLayers - 1)) * usableWidth;
        const numNodesInLayer = layerSizes[l];

        // Calculate vertical spacing to center the layer
        const layerHeight = (numNodesInLayer - 1) * 57.5;
        const startY = (height - layerHeight) / 2;

        // The consistent size for every node in THIS layer
        const baseRadius = layerRadii[l];

        for (let n = 0; n < numNodesInLayer; n++) {
          // Add a slight jitter for a jaggy, hand-drawn look
          const x = layerX + random(-10, 10);
          const y = startY + n * 57.5 + random(-10, 10);

          nodes.push({
            x, y,
            targetX: x, targetY: y,
            radius: baseRadius,
            baseRadius,
            layer: l
          });
        }
      }

      // Create connections (feed-forward)
      for (let i = 0; i < nodes.length; i++) {
        const nodeA = nodes[i];

        // Connect to nodes in the NEXT layer only for a clean structural look
        const candidates = nodes.filter(n => n.layer === nodeA.layer + 1);

        // Shuffle and connect to 2-4 nodes in the next layer
        candidates.sort(() => 0.5 - Math.random());
        const numConnections = Math.floor(random(2, 5));

        for (let j = 0; j < Math.min(numConnections, candidates.length); j++) {
          const nodeB = candidates[j];
          const dx = nodeB.x - nodeA.x;
          const dy = nodeB.y - nodeA.y;
          const distance = Math.sqrt(dx*dx + dy*dy);

          connections.push({
            from: nodeA,
            to: nodeB,
            width: random(1, 2.5),
            distance
          });
        }
      }
    }

    function spawnActivation() {
      if (connections.length === 0) return;
      const connection = connections[Math.floor(Math.random() * connections.length)];
      activations.push({
        connection,
        progress: 0,
        speed: random(0.003, 0.008) // Very slow, calm traveling
      });
    }

    function animate() {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);

      // Keep time moving slowly for the gentle pulsing, but do NOT move the physical x/y of the nodes
      time += 0.005;

      // Draw connections
      ctx.lineCap = 'round';
      for (const conn of connections) {
        ctx.beginPath();
        ctx.moveTo(conn.from.x, conn.from.y);
        ctx.lineTo(conn.to.x, conn.to.y);
        ctx.strokeStyle = lineColor;
        ctx.lineWidth = conn.width;
        ctx.stroke();
      }

      // Very low spawn rate for a calm, quiet atmosphere
      if (Math.random() < 0.03) spawnActivation();

      for (let i = activations.length - 1; i >= 0; i--) {
        const act = activations[i];
        act.progress += act.speed;

        if (act.progress >= 1) {
          activations.splice(i, 1);
          // Very rare chain reaction
          if (Math.random() > 0.8) {
             const nextConns = connections.filter(c => c.from === act.connection.to);
             if(nextConns.length > 0) {
                 const next = nextConns[Math.floor(Math.random() * nextConns.length)];
                 activations.push({ connection: next, progress: 0, speed: random(0.003, 0.008) });
             }
          }
          continue;
        }

        const x = act.connection.from.x + (act.connection.to.x - act.connection.from.x) * act.progress;
        const y = act.connection.from.y + (act.connection.to.y - act.connection.from.y) * act.progress;

        ctx.beginPath();
        ctx.arc(x, y, act.connection.width + 1.5, 0, Math.PI * 2);
        ctx.fillStyle = activationColor;
        ctx.shadowColor = activationColor;
        ctx.shadowBlur = 6;
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      // Draw nodes
      for (const node of nodes) {
        ctx.beginPath();
        // Very subtle, slow pulsing
        const currentRadius = node.baseRadius + Math.sin(time + node.x) * 0.5;
        ctx.arc(node.x, node.y, Math.max(1, currentRadius), 0, Math.PI * 2);
        ctx.fillStyle = nodeColor;
        ctx.fill();

        // Add a cartoon-style black border
        ctx.strokeStyle = '#111111'; // Dark border for cell-shaded cartoon look
        ctx.lineWidth = 2.5;
        ctx.stroke();

        // Add a subtle glowing core to larger nodes
        if (node.baseRadius > 10) {
          ctx.beginPath();
          ctx.arc(node.x, node.y, node.baseRadius * 0.3, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255,255,255,0.15)';
          ctx.fill();
        }
      }

      requestAnimationFrame(animate);
    }

    buildNetwork();
    animate();
  }

  // Initialize
  initANN();
  document.addEventListener('astro:page-load', initANN);
</script>

<style>
  .neuron-container {
    width: 100%;
    height: 472px;
    background: radial-gradient(circle at center, var(--surface-card) 0%, var(--surface-bg) 100%);
    border-radius: var(--radius-lg);
    border: 1px solid var(--surface-border);
    margin: 3rem 0 4rem;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }
</style>
