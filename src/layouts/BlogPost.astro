---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, AUTHOR_NAME } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { wordCount?: number };

const { title, description, pubDate, updatedDate, heroImage, wordCount } = Astro.props;

const readingTime = Math.ceil((wordCount ?? description?.split(' ')?.length ?? 200) / 200) || 1;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: { '@type': 'Person', name: AUTHOR_NAME },
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  publisher: {
    '@type': 'Organization',
    name: SITE_TITLE,
    logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).href },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(Astro.url.pathname, Astro.site).href },
};
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="module">
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

      const getMermaidTheme = () =>
        document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'neutral';

      const renderDiagrams = async () => {
        // Remove any previously rendered SVGs and restore divs
        document.querySelectorAll('.mermaid[data-processed]').forEach(el => {
          el.removeAttribute('data-processed');
          el.innerHTML = el.getAttribute('data-src') ?? el.innerHTML;
        });

        mermaid.initialize({ startOnLoad: false, theme: getMermaidTheme(), securityLevel: 'loose' });
        await mermaid.run({ querySelector: '.mermaid' });
      };

      document.addEventListener('DOMContentLoaded', async () => {
        const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
        for (const pre of blocks) {
          const div = document.createElement('div');
          div.className = 'mermaid';
          const src = pre.querySelector('code')?.textContent ?? pre.textContent;
          div.setAttribute('data-src', src);
          div.textContent = src;
          pre.replaceWith(div);
        }
        await renderDiagrams();
      });

      // Re-render when theme changes
      const observer = new MutationObserver(() => renderDiagrams());
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    </script>
  </head>

  <body>
    <Header />

    <main id="main-content">
      <article>
        <!-- Hero Image -->
        {heroImage && (
          <div class="hero-image">
            <Image
              width={1020}
              height={510}
              src={heroImage}
              alt=""
              loading="eager"
            />
          </div>
        )}

        <!-- Article Header -->
        <header class="article-header reveal">
          <div class="article-meta">
            <a href="/blog" class="back-link">← Writing</a>
            <div class="article-meta-right">
              <time class="article-date">
                <FormattedDate date={pubDate} />
              </time>
              <span class="article-reading-time">{readingTime} {readingTime === 1 ? 'min' : 'mins'} read</span>
            </div>
          </div>
          <h1 class="article-title">{title}</h1>
          {description && (
            <p class="article-description">{description}</p>
          )}
          {updatedDate && (
            <p class="article-updated">
              Updated <FormattedDate date={updatedDate} />
            </p>
          )}
        </header>

        <!-- Article Body -->
        <div class="prose">
          <slot />
        </div>


      </article>
    </main>

    <Footer />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0;
  }

  article {
    max-width: 100%;
  }

  /* ─── Article Header ─── */
  .article-header {
    max-width: var(--max-prose);
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .article-meta-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .back-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .back-link:hover {
    color: var(--text-primary);
    text-decoration: none;
  }

  .article-date {
    font-size: 0.8125rem;
    color: var(--text-muted);
    letter-spacing: 0.01em;
  }

  .article-reading-time {
    font-size: 0.75rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(1.875rem, 5vw, 3rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .article-description {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
    max-width: 560px;
  }

  .article-updated {
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--text-muted);
    margin-top: 0.75rem;
    margin-bottom: 0;
  }

  /* ─── Hero Image ─── */
  .hero-image {
    max-width: 900px;
    margin: 2rem auto 0;
    padding: 0 1.5rem;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    display: block;
  }

  /* ─── Prose ─── */
  .prose {
    max-width: var(--max-prose);
    margin: 3rem auto 0;
    padding: 0 1.5rem 4rem;
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    margin-top: 2.5em;
    color: var(--text-primary);
  }

  .prose :global(h2) {
    font-size: 1.625rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--surface-border);
  }

  .prose :global(a) {
    color: var(--link);
    text-decoration-color: color-mix(in oklab, var(--link) 40%, transparent);
    font-weight: 450;
  }

  .prose :global(a:hover) {
    color: var(--link-hover);
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    margin: 2rem 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    color: var(--text-secondary);
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
  }

  .prose :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    min-width: 0;
  }

  .prose :global(pre) {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* Mermaid diagram centering */
  .prose :global(.mermaid) {
    text-align: center;
    margin: 2rem 0;
    overflow-x: auto;
  }

  @media (max-width: 640px) {
    .article-header {
      padding: 2.5rem 1.25rem 1.5rem;
    }
    .prose {
      padding: 0 1.25rem 3rem;
      font-size: 1rem;
    }
  }

  /* ─── Article Footer ─── */
  .article-footer {
    border-top: 1px solid var(--surface-border);
    background-color: var(--surface-paper);
    transition:
      background-color var(--dur-normal) var(--ease-out),
      border-color var(--dur-normal) var(--ease-out);
  }

  .article-footer-inner {
    max-width: var(--max-prose);
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-brand-icon {
    font-size: 1.25rem;
    color: var(--accent);
    flex-shrink: 0;
  }

  .footer-credit {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0 0 0.25rem;
  }

  .footer-back {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .footer-back:hover {
    color: var(--accent-hover);
    text-decoration: none;
  }
</style>
